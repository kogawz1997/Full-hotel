{
  "installCommand": "npm install --legacy-peer-deps --no-audit --no-fund",
  "buildCommand": "npm run build",
  "crons": [
    {
      "path": "/api/cron/pre-arrival",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/post-stay",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/night-audit",
      "schedule": "0 18 * * *"
    },
    {
      "path": "/api/cron/tm30-reminder",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/daily-summary",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron/no-show",
      "schedule": "30 18 * * *"
    },
    {
      "path": "/api/cron/trial-expire",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/ota/process",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/expire-pending",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/cron/trial-expiry",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron/ota-sync",
      "schedule": "0 6 * * *"
    }
  ]
}