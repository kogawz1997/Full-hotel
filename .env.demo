# ─────────────────────────────────────────────────────────────────────────────
# ADDITIONAL REQUIRED VARS (added after audit)
# ─────────────────────────────────────────────────────────────────────────────

# Cron job auth (random string — generate with: openssl rand -hex 32)
CRON_SECRET=demo_cron_secret_maitri_2024_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# WhatsApp webhook verification (needed by webhook handler)
WHATSAPP_APP_SECRET=demo_whatsapp_app_secret_xxxxxxxxxxxxxxxxxxxxxxxxx

# Thai Immigration API (for TM30 — apply at immigration.go.th)
IMMIGRATION_API_KEY=demo_immigration_api_key_not_real_placeholder

# Node environment
NODE_ENV=development

# ─── Upstash Redis (Rate Limiting) ────────────────────────────────────────────
# Get from: https://upstash.com → Create Redis DB (free) → REST API tab
UPSTASH_REDIS_REST_URL=https://YOUR_DB.upstash.io
UPSTASH_REDIS_REST_TOKEN=YOUR_TOKEN_HERE

# ─── Stripe (Subscription Billing) ───────────────────────────────────────────
# Get from: https://dashboard.stripe.com → API Keys
STRIPE_SECRET_KEY=sk_test_YOUR_KEY
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_KEY
# Get from: Stripe → Webhooks → Add endpoint → /api/billing/webhook
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET
# Get from: Stripe → Products → Create product per plan → copy Price ID
STRIPE_PRICE_STARTER=price_YOUR_STARTER_PRICE_ID
STRIPE_PRICE_STANDARD=price_YOUR_STANDARD_PRICE_ID
STRIPE_PRICE_PRO=price_YOUR_PRO_PRICE_ID

# ─── Sentry (Error Tracking) ──────────────────────────────────────────────────
# Get from: https://sentry.io → Create Project → Next.js → copy DSN
SENTRY_DSN=https://YOUR_KEY@oXXXXXX.ingest.sentry.io/XXXXXXX
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=maitri-pms
NEXT_PUBLIC_SENTRY_DSN=https://YOUR_KEY@oXXXXXX.ingest.sentry.io/XXXXXXX
